{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>containers/automation//renovate/defaults.json5"
    ],
    "ignorePaths": [
        "container-images/common/*.txt"
    ],
    "lockFileMaintenance": {
        "schedule": [
            "* 0-9 * * 1"
        ]
    },
    "packageRules": [
        {
            "groupName": "CI updates",
            "matchCategories": ["ci"]
        },
        {
            "groupName": "python updates",
            "matchCategories": ["python"]
        }
    ],
    "schedule": [
        "* 0-9 * * 1"
    ]
}
